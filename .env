# API Keys (逗号分隔多个 key)
API_KEYS=key1,key2

# 账号配置 (JSON 格式数组)
# 每个账号必须包含 password，以及 email 或 mobile 其中之一
# token 字段可选，登录成功后会自动更新
ACCOUNTS=[{"email":"example1@example.com","password":"password1","token":""},{"email":"example2@example.com","password":"password2","token":""},{"mobile":"12345678901","password":"password3","token":""},{"mobile":"12345678901","password":"password4","token":""}]

# Claude 模型映射配置
CLAUDE_MODEL_MAPPING={"fast":"deepseek-chat","slow":"deepseek-chat"}